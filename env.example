# ---------------------------------------------------------------------------
# Titan Email (Hostinger) / Nodemailer – Contact form
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your real values. Do not commit .env.

SMTP_HOST=smtp.titan.email
SMTP_PORT=465
SMTP_USER=contact@63agency.com
SMTP_PASS=your_titan_password_here
ADMIN_EMAIL=contact@63agency.com
FROM_NAME=63 Agency

# ---------------------------------------------------------------------------
# Optional: EmailJS (if you use the client-side contact form with EmailJS)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID_ADMIN=
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID_CLIENT=
# NEXT_PUBLIC_EMAILJS_ADMIN_EMAIL=contact@63agency.com
